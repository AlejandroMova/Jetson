# TensorRT engines — architecture-specific, regenerated automatically on each device
*.engine

# Large model weights — too big or not needed in repo
*.etlt
*.tlt
*.pth
*.pt

# Dev/experimental ONNX files — only deploy/models ONNX files are tracked
dev/models/**/*.onnx

# Compiled shared libraries — must be recompiled per architecture (x86 vs ARM64)
*.so

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Outputs / temp
crops/
results/
results_model_fb/
*.jpg
*.jpeg
*.png
*.mp4

# Client credentials — copy .env.example → .env and fill in per deployment
clients/**/.env

# Deploy-level secrets (API_KEY, API_BASE_URL)
deploy/.env

# IDE
.vscode/
.claude/

# Misc
*.zip
ngc-cli/
deepstream_examples/
PLATFORM/
TEST/
