# Docker Compose environment — copy to .env and fill in real values.
# .env is gitignored — never commit it.

# NX Computing backend
API_BASE_URL=https://api.nxcomputing.ai
API_KEY=your-jetson-api-token-here

# WebSocket position telemetry — leave empty to disable (no error if unset)
# The Jetson connects as client to WS_BASE_URL/ws/positions
WS_BASE_URL=

# Device identity (shows up in every API event)
JETSON_ID=jetson-nx-001
