# DVR credentials — never commit
clients/*/.env

# Face recognition database — per-deployment, not tracked
clients/*/known_faces.json

# Face photos used to generate embeddings — stay on admin laptop
clients/*/faces/

# TensorRT engines — rebuilt per device, large binaries
models/**/*.engine

# InsightFace downloaded models
models/insightface/

# MoveNet ONNX (downloaded by tools/download_models.py)
models/movenet/

# OSNet binaries — downloaded/compiled per device, not tracked
# The nvinfer config (.txt) IS tracked so it deploys via git pull
models/osnet/*.onnx
models/osnet/*.trt

# Person crops dataset
crops/

# Python
__pycache__/
*.pyc